#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_CLI="${SCRIPT_DIR}/../runtime/armbian-ota"

if [ ! -x "${RUNTIME_CLI}" ]; then
    RUNTIME_CLI="/usr/sbin/armbian-ota"
fi

case "${1:-}" in
    prepare|start)
        exec "${RUNTIME_CLI}" start --mode=recovery "$2"
        ;;
    status)
        exec "${RUNTIME_CLI}" status
        ;;
    mark-success)
        exec "${RUNTIME_CLI}" mark-success
        ;;
    rollback)
        exec "${RUNTIME_CLI}" rollback
        ;;
    *)
        echo "Usage: $0 {prepare|start|status|mark-success|rollback} [package]" >&2
        exit 1
        ;;
esac
