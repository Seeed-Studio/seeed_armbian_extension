#!/bin/sh
#
# initramfs-tools init-premount hook: OTA update

PREREQ=""

prereqs() {
    echo "$PREREQ"
}

case "$1" in
    prereqs)
        prereqs
        exit 0
        ;;
esac

# ===== logging: file + /dev/kmsg =====
LOGDIR=/run/initramfs
LOGFILE=${LOGDIR}/ota.log
mkdir -p "$LOGDIR"

# increase printk level so /dev/kmsg goes to console
echo "8 4 1 7" > /proc/sys/kernel/printk 2>/dev/null || true

log() {
    echo "OTA_DEBG $*" >> "$LOGFILE" 2>/dev/null || true
    echo "OTA_DEBG $*" > /dev/kmsg 2>/dev/null || true
}

# ===== heartbeat for long-running operations =====
HEARTBEAT_PID=""

start_heartbeat() {
    msg="$1"
    (
        while :; do
            echo "OTA_DEBG [HB] $msg" >> "$LOGFILE" 2>/dev/null || true
            echo "OTA_DEBG [HB] $msg" > /dev/kmsg 2>/dev/null || true
            sleep 10
        done
    ) &
    HEARTBEAT_PID=$!
}

stop_heartbeat() {
    if [ -n "$HEARTBEAT_PID" ]; then
        kill "$HEARTBEAT_PID" 2>/dev/null || true
        HEARTBEAT_PID=""
    fi
}

# ===== tar extract helper with fallback and stderr logging =====
extract_tar_with_fallback() {
    archive="$1"
    target="$2"
    label="$3"
    err_file="${LOGDIR}/${label}.tar.stderr.log"
    rc=0

    rm -f "${err_file}" 2>/dev/null || true

    # Preferred mode: preserve metadata when supported.
    log "${label}: run tar --xattrs --acls --numeric-owner -xpf ${archive} -C ${target}"
    if tar --xattrs --acls --numeric-owner -xpf "${archive}" -C "${target}" 2>"${err_file}"; then
        log "${label}: metadata extract succeeded"
        if [ -s "${err_file}" ]; then
            log "${label}: tar metadata mode produced stderr, showing last lines"
            tail -n 20 "${err_file}" 2>/dev/null | while IFS= read -r l; do log "${label}: ${l}"; done
        fi
        rm -f "${err_file}" 2>/dev/null || true
        return 0
    fi
    rc=$?

    log "WARN: ${label} metadata extract failed (rc=${rc}), retrying with plain tar -xzf"
    if [ -s "${err_file}" ]; then
        tail -n 40 "${err_file}" 2>/dev/null | while IFS= read -r l; do log "${label} metadata stderr: ${l}"; done
    fi

    rm -f "${err_file}" 2>/dev/null || true
    log "${label}: run tar -xzf ${archive} -C ${target}"
    if tar -xzf "${archive}" -C "${target}" 2>"${err_file}"; then
        log "${label}: plain extract succeeded"
        if [ -s "${err_file}" ]; then
            log "${label}: plain tar mode produced stderr, showing last lines"
            tail -n 20 "${err_file}" 2>/dev/null | while IFS= read -r l; do log "${label}: ${l}"; done
        fi
        rm -f "${err_file}" 2>/dev/null || true
        return 0
    fi
    rc=$?

    log "ERROR: ${label} extract failed in both metadata and plain modes (plain rc=${rc})"
    if [ -s "${err_file}" ]; then
        tail -n 80 "${err_file}" 2>/dev/null | while IFS= read -r l; do log "${label} stderr: ${l}"; done
    fi
    rm -f "${err_file}" 2>/dev/null || true
    return 1
}

# enable shell trace (goes into log/kmsg)
set -x

[ -f /scripts/functions ] && . /scripts/functions

# default fallback devices (if detection fails)
ROOT_DEV=""
BOOT_DEV=""

ROOT_MNT="/mnt/root"
BOOT_MNT="/mnt/boot"
STATE_DIR="${ROOT_MNT}/var/lib/armbian-ota"
STATE_FILE="${STATE_DIR}/state.env"

OTA_DIR="${ROOT_MNT}/ota_work"
ROOTFS_TAR="${OTA_DIR}/rootfs.tar.gz"
BOOT_TAR="${OTA_DIR}/boot.tar.gz"
PRESERVE_LIST="${ROOT_MNT}/etc/armbian-ota/back-list.txt"
PRESERVE_TAR="${OTA_DIR}/ota-preserve.tar"
PRESERVE_TMP_LIST="${LOGDIR}/ota-preserve.list"

log "init-premount ota hook start"
log "LOGFILE=${LOGFILE}"

touch "${LOGDIR}/ota_ran.init-premount"

# ===== helper: preserve selected files across recovery OTA =====
prepare_preserve_list() {
    raw=""
    line=""
    rel=""
    target=""

    rm -f "${PRESERVE_TMP_LIST}" 2>/dev/null || true
    [ -f "${PRESERVE_LIST}" ] || {
        log "preserve list not found: ${PRESERVE_LIST}, skip preserve step"
        return 1
    }

    while IFS= read -r raw || [ -n "${raw}" ]; do
        line="$(echo "${raw}" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')"
        case "${line}" in
            ""|\#*) continue ;;
        esac
        case "${line}" in
            /*) ;;
            *)
                log "preserve: skip non-absolute path: ${line}"
                continue
                ;;
        esac
        case "${line}" in
            "/"|"/."|"/.."|*"../"*|*"/.."|*"*"*|*"?"*|*"["*|*"]"*)
                log "preserve: skip unsafe pattern: ${line}"
                continue
                ;;
        esac

        rel="${line#/}"
        [ -n "${rel}" ] || continue
        target="${ROOT_MNT}/${rel}"
        if [ -e "${target}" ] || [ -L "${target}" ]; then
            printf '%s\n' "${rel}" >> "${PRESERVE_TMP_LIST}"
        else
            log "preserve: path not found, skip: ${line}"
        fi
    done < "${PRESERVE_LIST}"

    if [ ! -s "${PRESERVE_TMP_LIST}" ]; then
        log "preserve: no valid entries found in ${PRESERVE_LIST}"
        rm -f "${PRESERVE_TMP_LIST}" 2>/dev/null || true
        return 1
    fi

    return 0
}

backup_preserved_files() {
    err_file="${LOGDIR}/preserve.backup.stderr.log"
    rc=0
    rm -f "${PRESERVE_TAR}" "${err_file}" 2>/dev/null || true

    prepare_preserve_list || return 0
    log "preserve: backing up whitelisted files to ${PRESERVE_TAR}"

    if tar --xattrs --acls --numeric-owner -cpf "${PRESERVE_TAR}" -C "${ROOT_MNT}" -T "${PRESERVE_TMP_LIST}" 2>"${err_file}"; then
        log "preserve: backup completed (metadata mode)"
        rm -f "${err_file}" 2>/dev/null || true
        return 0
    fi
    rc=$?
    log "preserve: metadata backup failed rc=${rc}, retry plain tar mode"
    if [ -s "${err_file}" ]; then
        tail -n 40 "${err_file}" 2>/dev/null | while IFS= read -r l; do log "preserve backup stderr: ${l}"; done
    fi

    rm -f "${err_file}" 2>/dev/null || true
    if tar -cpf "${PRESERVE_TAR}" -C "${ROOT_MNT}" -T "${PRESERVE_TMP_LIST}" 2>"${err_file}"; then
        log "preserve: backup completed (plain mode)"
        rm -f "${err_file}" 2>/dev/null || true
        return 0
    fi

    rc=$?
    log "WARN: preserve backup failed rc=${rc}, continue without preserve"
    if [ -s "${err_file}" ]; then
        tail -n 60 "${err_file}" 2>/dev/null | while IFS= read -r l; do log "preserve backup stderr: ${l}"; done
    fi
    rm -f "${PRESERVE_TAR}" "${PRESERVE_TMP_LIST}" "${err_file}" 2>/dev/null || true
    return 0
}

restore_preserved_files() {
    if [ ! -f "${PRESERVE_TAR}" ]; then
        log "preserve: no backup archive found, skip restore"
        return 0
    fi

    log "preserve: restoring whitelisted files from ${PRESERVE_TAR}"
    start_heartbeat "restoring preserved files"
    if ! extract_tar_with_fallback "${PRESERVE_TAR}" "${ROOT_MNT}" "preserve"; then
        stop_heartbeat
        log "WARN: preserve restore failed, continue OTA"
        rm -f "${PRESERVE_TAR}" "${PRESERVE_TMP_LIST}" 2>/dev/null || true
        return 0
    fi
    stop_heartbeat
    rm -f "${PRESERVE_TAR}" "${PRESERVE_TMP_LIST}" 2>/dev/null || true
    log "preserve: restore completed"
    return 0
}

# ===== helper: get UUID by LABEL using blkid =====
get_uuid_by_label() {
    label="$1"
    blkid 2>/dev/null | awk -v lbl="$label" '
        /LABEL="/ {
            l = ""; u = ""
            for (i = 1; i <= NF; i++) {
                if ($i ~ /^LABEL="/) {
                    x = $i
                    gsub(/LABEL="/, "", x)
                    gsub(/"$/, "", x)
                    l = x
                }
                if ($i ~ /^UUID="/) {
                    y = $i
                    gsub(/UUID="/, "", y)
                    gsub(/"$/, "", y)
                    u = y
                }
            }
            if (l == lbl && u != "") {
                print u
                exit
            }
        }'
}

# ===== helper: get DEV + UUID by LABEL (e.g. /dev/mmcblk0p5 + UUID) =====
get_dev_and_uuid_by_label() {
    label="$1"
    blkid 2>/dev/null | awk -v lbl="$label" '
        $0 ~ ("LABEL=\"" lbl "\"") {
            dev = $1
            sub(":", "", dev)  # strip trailing colon
            uuid = ""
            for (i = 1; i <= NF; i++) {
                if ($i ~ /^UUID="/) {
                    uuid = $i
                    gsub(/UUID="/, "", uuid)
                    gsub(/"$/, "", uuid)
                    break
                }
            }
            if (uuid != "") {
                print dev, uuid
                exit
            }
        }'
}

# ===== helper: get LUKS UUID for encrypted root backing device =====
get_luks_uuid_for_root() {
    blkid -t TYPE=crypto_LUKS -s UUID -o value 2>/dev/null | head -n1
}

# ===== detect firmware mode and root/boot devices =====
ROOT_UUID=""
BOOT_UUID=""
HAS_BOOT_PART=0
AUTO_DECRYPT_MODE=0
SECURITY_PART=""

SECURITY_PART="$(blkid -t PARTLABEL=security -o device 2>/dev/null | head -n1 || true)"
if [ -n "${SECURITY_PART}" ]; then
    log "security partition found at ${SECURITY_PART}, checking mapper /dev/mapper/armbian-root"
    timeout=30
    elapsed=0
    while [ ! -e /dev/mapper/armbian-root ] && [ "${elapsed}" -lt "${timeout}" ]; do
        sleep 1
        elapsed=$((elapsed + 1))
    done

    if [ -e /dev/mapper/armbian-root ]; then
        AUTO_DECRYPT_MODE=1
        ROOT_DEV="/dev/mapper/armbian-root"
        ROOT_UUID="$(get_luks_uuid_for_root || true)"
        log "auto-decrypt mode detected: ROOT_DEV=${ROOT_DEV}, LUKS_UUID=${ROOT_UUID:-<empty>}"
    else
        log "security partition exists but mapper /dev/mapper/armbian-root is not ready, fallback to standard mode"
    fi
else
    log "security partition not found, using standard recovery OTA mode"
fi

boot_info="$(get_dev_and_uuid_by_label "armbi_boot" || true)"

if [ "${AUTO_DECRYPT_MODE}" -eq 0 ]; then
    root_info="$(get_dev_and_uuid_by_label "armbi_root" || true)"
    if [ -n "$root_info" ]; then
        ROOT_DEV="$(echo "$root_info" | awk '{print $1}')"
        ROOT_UUID="$(echo "$root_info" | awk '{print $2}')"
    fi
    log "standard mode root detection: ROOT_DEV=${ROOT_DEV}, ROOT_UUID=${ROOT_UUID}"
else
    log "auto-decrypt mode root detection: skip armbi_root label probing"
fi

if [ -n "$boot_info" ]; then
    BOOT_DEV="$(echo "$boot_info" | awk '{print $1}')"
    BOOT_UUID="$(echo "$boot_info" | awk '{print $2}')"
    HAS_BOOT_PART=1
fi

log "auto-detected BOOT_DEV=${BOOT_DEV}, BOOT_UUID=${BOOT_UUID}, HAS_BOOT_PART=${HAS_BOOT_PART}"

# ===== 1) mount rootfs to /mnt/root =====
if [ -z "${ROOT_DEV}" ]; then
    log "ROOT_DEV is empty, skip OTA"
    exit 0
fi

mkdir -p "${ROOT_MNT}"
log "mounting ${ROOT_DEV} -> ${ROOT_MNT} ..."
if ! mount -t ext4 -o rw "${ROOT_DEV}" "${ROOT_MNT}"; then
    log "cannot mount ${ROOT_DEV}, skip OTA"
    exit 0
fi

# check OTA payload: rootfs.tar.gz is required, boot.tar.gz is optional
if [ ! -d "${OTA_DIR}" ] || [ ! -f "${ROOTFS_TAR}" ]; then
    log "no rootfs OTA payload at ${OTA_DIR}, unmount and skip"
    umount "${ROOT_MNT}" 2>/dev/null || true
    exit 0
fi

HAS_BOOT_TAR=0
if [ -f "${BOOT_TAR}" ]; then
    HAS_BOOT_TAR=1
fi

log "found rootfs OTA payload, HAS_BOOT_PART=${HAS_BOOT_PART}, HAS_BOOT_TAR=${HAS_BOOT_TAR}"

# preserve whitelist paths before cleaning old rootfs
backup_preserved_files

# ===== 2) clean rootfs (except ota_work and boot) =====
log "cleaning ${ROOT_MNT} (except ota_work ota_work and boot)..."
start_heartbeat "cleaning rootfs at ${ROOT_MNT}"
(
    cd "${ROOT_MNT}" || exit 1
    for f in * .[!.]* ..?*; do
        case "$f" in
            "."|".."|"ota_work"|"boot")
                continue
                ;;
        esac
        rm -rf "$f"
    done
) || {
    stop_heartbeat
    log "ERROR: failed to clean ${ROOT_MNT}, abort OTA"
    umount "${ROOT_MNT}" 2>/dev/null || true
    exit 0
}
stop_heartbeat

# ===== 3) extract rootfs.tar.gz =====
log "extracting ${ROOTFS_TAR} -> ${ROOT_MNT} ..."
start_heartbeat "extracting rootfs.tar.gz to ${ROOT_MNT}"
if ! extract_tar_with_fallback "${ROOTFS_TAR}" "${ROOT_MNT}" "rootfs"; then
    stop_heartbeat
    log "ERROR: extract rootfs.tar.gz failed, abort OTA"
    umount "${ROOT_MNT}" 2>/dev/null || true
    exit 0
fi
stop_heartbeat

sync
restore_preserved_files

# Force-disable Armbian first-login marker after OTA. If new rootfs ships this
# file, root login would trigger first-login flow unexpectedly.
if rm -f "${ROOT_MNT}/root/.not_logged_in_yet" 2>/dev/null; then
    log "removed ${ROOT_MNT}/root/.not_logged_in_yet to avoid first-login re-trigger"
fi

# Clean stale getty autologin overrides. These are normally removed by
# armbian-firstlogin; when firstlogin is skipped they may persist.
for ov in \
    "${ROOT_MNT}/etc/systemd/system/getty@.service.d/override.conf" \
    "${ROOT_MNT}/etc/systemd/system/serial-getty@.service.d/override.conf"
do
    if [ -f "${ov}" ]; then
        if grep -Eq -- 'autologin|--autologin' "${ov}" 2>/dev/null; then
            if rm -f "${ov}" 2>/dev/null; then
                log "removed stale autologin override: ${ov}"
            else
                log "WARN: failed to remove stale autologin override: ${ov}"
            fi
        else
            log "keep non-autologin override: ${ov}"
        fi
    fi
done

# ===== 4) if we have separate boot partition + boot.tar.gz, handle boot OTA =====
DO_BOOT_OTA=0
if [ "$HAS_BOOT_PART" -eq 1 ] && [ "$HAS_BOOT_TAR" -eq 1 ]; then
    DO_BOOT_OTA=1
fi

if [ "$DO_BOOT_OTA" -eq 1 ]; then
    log "boot OTA enabled (separate boot partition + boot.tar.gz present)"

    mkdir -p "${BOOT_MNT}"
    log "mounting ${BOOT_DEV} -> ${BOOT_MNT} ..."
    if ! mount -t ext4 -o rw "${BOOT_DEV}" "${BOOT_MNT}"; then
        log "ERROR: mount ${BOOT_DEV} failed, skip boot OTA"
        BOOT_MNT=""
        DO_BOOT_OTA=0
    fi
else
    log "boot OTA disabled (no separate boot partition or no boot.tar.gz)"
fi

if [ "$DO_BOOT_OTA" -eq 1 ]; then
    # ===== 5) clean boot partition =====
    # log "cleaning ${BOOT_MNT} ..."
    # start_heartbeat "cleaning boot at ${BOOT_MNT}"
    # (
    #     cd "${BOOT_MNT}" || exit 1
    #     for f in * .[!.]* ..?*; do
    #         case "$f" in
    #             "."|"..")
    #                 continue
    #                 ;;
    #         esac
    #         rm -rf "$f"
    #     done
    # ) || {
    #     stop_heartbeat
    #     log "WARN: failed to clean ${BOOT_MNT}, continue anyway"
    # }
    # stop_heartbeat

    # ===== 6) extract boot.tar.gz =====
    log "extracting ${BOOT_TAR} -> ${BOOT_MNT} ..."
    start_heartbeat "extracting boot.tar.gz to ${BOOT_MNT}"
    if ! extract_tar_with_fallback "${BOOT_TAR}" "${BOOT_MNT}" "boot"; then
        stop_heartbeat
        log "ERROR: extract boot.tar.gz failed, system may be broken"
    fi
    stop_heartbeat

    sync
fi

# ===== 7) fix UUIDs in armbianEnv.txt and new rootfs /etc/fstab =====

if [ "$DO_BOOT_OTA" -eq 1 ] && [ -n "${BOOT_MNT}" ]; then
    ARM_ENV="${BOOT_MNT}/armbianEnv.txt"
else
    ARM_ENV="${ROOT_MNT}/boot/armbianEnv.txt"
fi

FSTAB="${ROOT_MNT}/etc/fstab"
CRYPTTAB="${ROOT_MNT}/etc/crypttab"

# fallback UUID detection (just in case)
if [ "${AUTO_DECRYPT_MODE}" -eq 1 ]; then
    [ -z "$ROOT_UUID" ] && ROOT_UUID="$(get_luks_uuid_for_root)"
else
    [ -z "$ROOT_UUID" ] && ROOT_UUID="$(get_uuid_by_label "armbi_root")"
fi
[ -z "$BOOT_UUID" ] && BOOT_UUID="$(get_uuid_by_label "armbi_boot")"

log "final ROOT_UUID=${ROOT_UUID}, BOOT_UUID=${BOOT_UUID}"

# 7.1 patch armbianEnv.txt if present
if [ -f "${ARM_ENV}" ]; then
    log "patching ${ARM_ENV} ..."

    if [ "${AUTO_DECRYPT_MODE}" -eq 1 ]; then
        log "  - set rootdev=/dev/mapper/armbian-root"
        if grep -q '^rootdev=' "${ARM_ENV}"; then
            sed -i "s|^rootdev=.*$|rootdev=/dev/mapper/armbian-root|" "${ARM_ENV}"
        else
            printf '\nrootdev=/dev/mapper/armbian-root\n' >> "${ARM_ENV}"
        fi
    else
        if [ -n "${ROOT_UUID}" ]; then
            log "  - set rootdev=UUID=${ROOT_UUID}"
            if grep -q '^rootdev=' "${ARM_ENV}"; then
                sed -i "s|^rootdev=.*$|rootdev=UUID=${ROOT_UUID}|" "${ARM_ENV}"
            else
                printf '\nrootdev=UUID=%s\n' "${ROOT_UUID}" >> "${ARM_ENV}"
            fi
        else
            log "  - WARN: ROOT_UUID empty, skip rootdev change"
        fi
    fi

    # Keep existing console settings. Overriding serial console here may break
    # user-observed boot logs/login on boards using different UARTs.
    if grep -q '^console=' "${ARM_ENV}"; then
        log "  - keep existing console setting"
    else
        log "  - no console= in armbianEnv, leave unchanged"
    fi

    log "  - set verbosity=6"
    if grep -q '^verbosity=' "${ARM_ENV}"; then
        sed -i 's/^verbosity=.*/verbosity=6/' "${ARM_ENV}"
    else
        printf '\nverbosity=6\n' >> "${ARM_ENV}"
    fi
else
    log "WARN: ${ARM_ENV} not found, cannot patch rootdev/verbosity"
fi

# 7.2 patch new rootfs /etc/fstab
if [ -f "${FSTAB}" ]; then
    log "patching ${FSTAB} ..."

    if [ "${AUTO_DECRYPT_MODE}" -eq 1 ]; then
        log "  - update / entry to /dev/mapper/armbian-root"
        sed -i -E 's|^UUID=[^[:space:]]+[[:space:]]+/[[:space:]]+|/dev/mapper/armbian-root / |' "${FSTAB}"
        sed -i -E 's|^/dev/[^[:space:]]+[[:space:]]+/[[:space:]]+|/dev/mapper/armbian-root / |' "${FSTAB}"
    else
        if [ -n "${ROOT_UUID}" ]; then
            log "  - update / entry UUID to ${ROOT_UUID}"
            # lines like: UUID=xxxx / ext4 ...
            sed -i -E "s|^UUID=[^[:space:]]+[[:space:]]+/[[:space:]]+|UUID=${ROOT_UUID} / |" "${FSTAB}"
        else
            log "  - WARN: ROOT_UUID empty, skip / fstab entry update"
        fi
    fi

    if [ -n "${BOOT_UUID}" ]; then
        log "  - update /boot entry UUID to ${BOOT_UUID}"
        # lines like: UUID=xxxx /boot ext4 ...
        sed -i -E "s|^UUID=[^[:space:]]+[[:space:]]+/boot[[:space:]]+|UUID=${BOOT_UUID} /boot |" "${FSTAB}"
    else
        log "  - WARN: BOOT_UUID empty, skip /boot fstab entry update"
    fi
else
    log "WARN: ${FSTAB} not found, skip fstab UUID patch"
fi

# 7.3 patch new rootfs /etc/crypttab for auto-decrypt mode
if [ "${AUTO_DECRYPT_MODE}" -eq 1 ]; then
    if [ -f "${CRYPTTAB}" ]; then
        if [ -n "${ROOT_UUID}" ]; then
            log "patching ${CRYPTTAB} ..."
            log "  - set armbian-root source UUID=${ROOT_UUID} (crypto_LUKS)"
            sed -i -E "s|^(armbian-root[[:space:]]+)UUID=[0-9a-fA-F-]+|\1UUID=${ROOT_UUID}|" "${CRYPTTAB}"
        else
            log "WARN: LUKS UUID empty, skip crypttab patch"
        fi
    else
        log "WARN: ${CRYPTTAB} not found, skip crypttab UUID patch"
    fi
fi

sync

log "  delete OTA payload directory ${OTA_DIR} ..."
rm -rf "${OTA_DIR}" || true
# ===== 8) unmount partitions =====
if [ "$DO_BOOT_OTA" -eq 1 ] && [ -n "${BOOT_MNT}" ]; then
    log "unmounting ${BOOT_MNT} ..."
    umount "${BOOT_MNT}" 2>/dev/null || log "WARN: umount ${BOOT_MNT} failed"
fi

log "unmounting ${ROOT_MNT} ..."
umount "${ROOT_MNT}" 2>/dev/null  || log "WARN: umount ${ROOT_MNT} failed"

sync

# ===== 8.5) update runtime state =====
mkdir -p "${STATE_DIR}"
if [ -f "${STATE_FILE}" ]; then
    sed -i 's/^OTA_MODE=.*/OTA_MODE=recovery/' "${STATE_FILE}" 2>/dev/null || true
    sed -i 's/^STATUS=.*/STATUS=success/' "${STATE_FILE}" 2>/dev/null || true
    sed -i "s/^COMPLETE_TIME=.*/COMPLETE_TIME=$(date -Iseconds)/" "${STATE_FILE}" 2>/dev/null || true
fi

# ===== 9) reboot =====
log "OTA done, rebooting..."

if [ -w /proc/sysrq-trigger ]; then
    echo b > /proc/sysrq-trigger
fi

if command -v reboot >/dev/null 2>&1; then
    reboot -f
fi

while :; do
    log "reboot failed, please power cycle"
    sleep 10
done
