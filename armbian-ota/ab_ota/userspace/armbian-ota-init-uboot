#!/bin/bash
#
# Initialize u-boot environment for AB partition OTA
# This script modifies u-boot environment to support A/B slot boot selection
# Supports NVMe, SD card (mmc), and eMMC (mmc) storage devices
#

set -e

FORCE_REINIT=0
if [ "${1:-}" = "--force" ]; then
    FORCE_REINIT=1
fi

# Logging
log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*"
}

log_info() {
    log "INFO: $@"
}

log_error() {
    log "ERROR: $@" >&2
}

# Check if already initialized
if [ "${FORCE_REINIT}" -eq 0 ] && [ -f /var/lib/armbian-ota/uboot_initialized ]; then
    log_info "u-boot AB environment already initialized"
    exit 0
fi

if [ "${FORCE_REINIT}" -eq 1 ]; then
    log_info "Force reinitialization requested"
fi

# Check if fw_setenv/fw_printenv exists
if ! command -v fw_printenv >/dev/null 2>&1 || ! command -v fw_setenv >/dev/null 2>&1; then
    log_error "fw_printenv/fw_setenv not found"
    exit 1
fi

log_info "=== Initializing u-boot AB partition boot environment ==="

get_partition_number_from_dev() {
    local dev="$1"
    local base
    base="$(basename "${dev}")"

    if [[ "${base}" =~ p([0-9]+)$ ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi

    if [[ "${base}" =~ ([0-9]+)$ ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi

    return 1
}

get_uboot_bootdev_from_part() {
    local dev="$1"
    local base
    base="$(basename "${dev}")"

    # /dev/mmcblk1p1 -> mmc 1
    if [[ "${base}" =~ ^mmcblk([0-9]+)p[0-9]+$ ]]; then
        echo "mmc ${BASH_REMATCH[1]}"
        return 0
    fi

    # /dev/nvme0n1p1 -> nvme 0
    if [[ "${base}" =~ ^nvme([0-9]+)n[0-9]+p[0-9]+$ ]]; then
        echo "nvme ${BASH_REMATCH[1]}"
        return 0
    fi

    return 1
}

resolve_physical_part_dev() {
    local dev="$1" pkname
    [ -n "${dev}" ] || return 1

    case "${dev}" in
        /dev/mapper/*|/dev/dm-*)
            pkname="$(lsblk -no PKNAME "${dev}" 2>/dev/null | head -n1)"
            if [ -n "${pkname}" ]; then
                echo "/dev/${pkname}"
                return 0
            fi
            ;;
    esac

    echo "${dev}"
}

get_part_dev_by_partlabel() {
    local partlabel="$1" dev
    dev="$(blkid -t PARTLABEL="${partlabel}" -o device 2>/dev/null | head -n1)"
    [ -n "${dev}" ] || return 1
    resolve_physical_part_dev "${dev}"
}

get_part_uuid() {
    local dev="$1"
    [ -n "${dev}" ] || return 1
    blkid -o value -s UUID "${dev}" 2>/dev/null | head -n1
}

get_fs_uuid_by_label() {
    local fslabel="$1"
    blkid -t LABEL="${fslabel}" -o value -s UUID 2>/dev/null | head -n1
}

# Detect slot partitions:
# - boot partitions by filesystem label (ext4 labels armbi_boota/bootb)
# - root partitions by GPT PARTLABEL first (rootfs_a/rootfs_b), which works
#   for both normal AB and encrypted AB (rootfs_b is locked by default).
boot_a_dev="$(blkid -t LABEL="armbi_boota" -o device 2>/dev/null | head -n1)"
boot_b_dev="$(blkid -t LABEL="armbi_bootb" -o device 2>/dev/null | head -n1)"
root_a_dev="$(get_part_dev_by_partlabel "rootfs_a" || true)"
root_b_dev="$(get_part_dev_by_partlabel "rootfs_b" || true)"

if [ -z "${root_a_dev}" ]; then
    root_a_dev="$(resolve_physical_part_dev "$(blkid -t LABEL="armbi_roota" -o device 2>/dev/null | head -n1)" || true)"
fi
if [ -z "${root_b_dev}" ]; then
    root_b_dev="$(resolve_physical_part_dev "$(blkid -t LABEL="armbi_rootb" -o device 2>/dev/null | head -n1)" || true)"
fi

if [ -z "${boot_a_dev}" ] || [ -z "${boot_b_dev}" ] || [ -z "${root_a_dev}" ] || [ -z "${root_b_dev}" ]; then
    log_error "Cannot find one or more A/B partitions by label"
    log_error "boot_a=${boot_a_dev:-<none>} boot_b=${boot_b_dev:-<none>} root_a=${root_a_dev:-<none>} root_b=${root_b_dev:-<none>}"
    exit 1
fi

ACTUAL_BOOT_A_PART=$(get_partition_number_from_dev "${boot_a_dev}" || true)
ACTUAL_BOOT_B_PART=$(get_partition_number_from_dev "${boot_b_dev}" || true)
ROOT_A_PART=$(get_partition_number_from_dev "${root_a_dev}" || true)
ROOT_B_PART=$(get_partition_number_from_dev "${root_b_dev}" || true)

if [ -z "${ACTUAL_BOOT_A_PART}" ] || [ -z "${ACTUAL_BOOT_B_PART}" ] || [ -z "${ROOT_A_PART}" ] || [ -z "${ROOT_B_PART}" ]; then
    log_error "Failed to parse one or more partition numbers from device names"
    log_error "boot_a=${boot_a_dev} boot_b=${boot_b_dev} root_a=${root_a_dev} root_b=${root_b_dev}"
    exit 1
fi

# Use detected partition mapping to support custom layouts
# (for example, with BIOS/EFI/security partitions).
BOOT_A_PART="${ACTUAL_BOOT_A_PART}"
BOOT_B_PART="${ACTUAL_BOOT_B_PART}"

BOOT_DEVTYPE=""
BOOT_DEVNUM=""
read -r BOOT_DEVTYPE BOOT_DEVNUM <<< "$(get_uboot_bootdev_from_part "${boot_a_dev}" || true)"
if [ -z "${BOOT_DEVTYPE}" ] || [ -z "${BOOT_DEVNUM}" ]; then
    log_error "Unsupported boot_a device for U-Boot bootcmd generation: ${boot_a_dev}"
    exit 1
fi

# Get partition UUIDs
boot_a_uuid="$(get_fs_uuid_by_label "armbi_boota")"
boot_b_uuid="$(get_fs_uuid_by_label "armbi_bootb")"
root_a_uuid="$(get_part_uuid "${root_a_dev}")"
root_b_uuid="$(get_part_uuid "${root_b_dev}")"

log_info "Detected partition layout:"
log_info "  boot_a: ${boot_a_dev} (partition ${BOOT_A_PART})"
log_info "  boot_b: ${boot_b_dev} (partition ${BOOT_B_PART})"
log_info "  root_a: ${root_a_dev} (partition ${ROOT_A_PART})"
log_info "  root_b: ${root_b_dev} (partition ${ROOT_B_PART})"
log_info "Detected boot media for U-Boot: ${BOOT_DEVTYPE} ${BOOT_DEVNUM}"

log_info "Partition UUIDs:"
log_info "  boot_a: ${boot_a_uuid:-<not found>}"
log_info "  boot_b: ${boot_b_uuid:-<not found>}"
log_info "  root_a: ${root_a_uuid:-<not found>}"
log_info "  root_b: ${root_b_uuid:-<not found>}"

# Save original bootcmd
if ! fw_printenv -n orig_bootcmd >/dev/null 2>&1; then
    orig_bootcmd=$(fw_printenv -n bootcmd 2>/dev/null || "")
    if [ -n "$orig_bootcmd" ]; then
        fw_setenv orig_bootcmd "${orig_bootcmd}"
        log_info "Saved original bootcmd"
    fi
fi

# Set default boot_slot if not exists
if ! fw_printenv -n boot_slot >/dev/null 2>&1; then
    fw_setenv boot_slot a
    log_info "Set boot_slot to 'a'"
fi

# Set boot_success if not exists
if ! fw_printenv -n boot_success >/dev/null 2>&1; then
    fw_setenv boot_success a
    log_info "Set boot_success to 'a'"
fi

# Set ota_in_progress if not exists
if ! fw_printenv -n ota_in_progress >/dev/null 2>&1; then
    fw_setenv ota_in_progress 0
    log_info "Set ota_in_progress to '0'"
fi

# Set try_count if not exists
if ! fw_printenv -n try_count >/dev/null 2>&1; then
    fw_setenv try_count 0
    log_info "Set try_count to '0'"
fi

# U-Boot level boot retry policy:
# - slot_retry_max: max boot attempts for target slot while ota_in_progress=1
# - slot_retry_left: remaining attempts before fallback to boot_success slot
if ! fw_printenv -n slot_retry_max >/dev/null 2>&1; then
    fw_setenv slot_retry_max 3
    log_info "Set slot_retry_max to '3'"
fi

if ! fw_printenv -n slot_retry_left >/dev/null 2>&1; then
    fw_setenv slot_retry_left "$(fw_printenv -n slot_retry_max 2>/dev/null || echo 3)"
    log_info "Set slot_retry_left to slot_retry_max"
fi

# ============================================================
# Set up distro_bootpart variables for each slot
# ============================================================
# Create a temporary file with all u-boot environment variables
TEMP_ENV=$(mktemp)

# Set partition numbers detected from labels
echo "distro_bootpart_a ${BOOT_A_PART}" >> "${TEMP_ENV}"
echo "distro_bootpart_b ${BOOT_B_PART}" >> "${TEMP_ENV}"
echo "ab_boot_devtype ${BOOT_DEVTYPE}" >> "${TEMP_ENV}"
echo "ab_boot_devnum ${BOOT_DEVNUM}" >> "${TEMP_ENV}"

log_info "Set distro_bootpart_a=${BOOT_A_PART}, distro_bootpart_b=${BOOT_B_PART}, ab_boot_devtype=${BOOT_DEVTYPE}, ab_boot_devnum=${BOOT_DEVNUM}"

# ============================================================
# Modify bootcmd to use slot-based booting
# ============================================================
# The new environment keeps standard distro_bootcmd scanning order.
# We only override scan_dev_for_boot_part so that for the selected
# boot media (ab_boot_devtype/ab_boot_devnum) it scans exactly one
# partition chosen by boot_slot (A or B). Other media use stock behavior.
cat >> "${TEMP_ENV}" << EOF
# U-Boot preboot guard for A/B OTA retry/fallback
ab_preboot if test "\${ota_in_progress}" = "1"; then if env exists slot_retry_max; then true; else setenv slot_retry_max 3; fi; if env exists slot_retry_left; then true; else setenv slot_retry_left \${slot_retry_max}; fi; if test "\${slot_retry_left}" = "0"; then if env exists boot_success; then setenv boot_slot \${boot_success}; else setenv boot_slot a; fi; setenv ota_in_progress 0; setenv slot_retry_left \${slot_retry_max}; saveenv; reset; fi; setexpr slot_retry_left \${slot_retry_left} - 1; saveenv; fi
# Keep normal boot flow (similar to non-OTA default)
bootcmd run ab_preboot; run boot_pci_enum; run distro_bootcmd; boot_fit; bootrkp
# Slot-aware partition selection only on AB boot media; others stay unchanged
scan_dev_for_boot_part if test "\${devtype}" = "\${ab_boot_devtype}" && test "\${devnum}" = "\${ab_boot_devnum}"; then if test "\${boot_slot}" = "b"; then setenv devplist \${distro_bootpart_b}; else setenv devplist \${distro_bootpart_a}; fi; else part list \${devtype} \${devnum} -bootable devplist; env exists devplist || setenv devplist 1; fi; boot_android \${devtype} \${devnum}; for distro_bootpart in \${devplist}; do if fstype \${devtype} \${devnum}:\${distro_bootpart} bootfstype; then run scan_dev_for_boot; fi; done
EOF

log_info "Modified bootcmd"

# Apply all environment variables at once
fw_setenv -s "${TEMP_ENV}"
rm -f "${TEMP_ENV}"

# ============================================================
# Mark as initialized
# ============================================================
mkdir -p /var/lib/armbian-ota
cat > /var/lib/armbian-ota/uboot_initialized << EOF
# u-boot AB partition environment initialized
$(date)
boot_a_part=${BOOT_A_PART}
boot_b_part=${BOOT_B_PART}
root_a_part=${ROOT_A_PART}
root_b_part=${ROOT_B_PART}
boot_a_dev=${boot_a_dev}
boot_b_dev=${boot_b_dev}
root_a_dev=${root_a_dev}
root_b_dev=${root_b_dev}
boot_devtype=${BOOT_DEVTYPE}
boot_devnum=${BOOT_DEVNUM}
boot_a_uuid=${boot_a_uuid}
boot_b_uuid=${boot_b_uuid}
root_a_uuid=${root_a_uuid}
root_b_uuid=${root_b_uuid}
EOF

log_info "=== u-boot AB environment initialization complete ==="
log_info "Please reboot for changes to take effect"
log_info "Current boot_slot: $(fw_printenv -n boot_slot)"
log_info "Current bootcmd: $(fw_printenv -n bootcmd)"

exit 0
