#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ -f "${SCRIPT_DIR}/common.sh" ]; then
    OTA_RUNTIME_DIR="${SCRIPT_DIR}"
elif [ -f /usr/share/armbian-ota/common.sh ]; then
    OTA_RUNTIME_DIR="/usr/share/armbian-ota"
else
    echo "ERROR: Cannot find OTA runtime libraries" >&2
    exit 1
fi

export OTA_RUNTIME_DIR

. "${OTA_RUNTIME_DIR}/common.sh"

HAS_AB_BACKEND=0
HAS_RECOVERY_BACKEND=0

if [ -f "${OTA_RUNTIME_DIR}/backend-ab.sh" ]; then
    . "${OTA_RUNTIME_DIR}/backend-ab.sh"
    HAS_AB_BACKEND=1
fi

if [ -f "${OTA_RUNTIME_DIR}/backend-recovery.sh" ]; then
    . "${OTA_RUNTIME_DIR}/backend-recovery.sh"
    HAS_RECOVERY_BACKEND=1
fi

require_mode_backend() {
    local mode="$1"
    case "${mode}" in
        ab)
            [ "${HAS_AB_BACKEND}" -eq 1 ] || error_exit "AB OTA backend is not installed on this firmware"
            ;;
        recovery)
            [ "${HAS_RECOVERY_BACKEND}" -eq 1 ] || error_exit "Recovery OTA backend is not installed on this firmware"
            ;;
    esac
}

parse_start_args() {
    OTA_CLI_MODE=""
    OTA_CLI_PACKAGE=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --mode=*)
                OTA_CLI_MODE="${1#--mode=}"
                shift
                ;;
            --mode)
                OTA_CLI_MODE="$2"
                shift 2
                ;;
            -*)
                error_exit "Unknown option: $1"
                ;;
            *)
                OTA_CLI_PACKAGE="$1"
                shift
                ;;
        esac
    done

    [ -n "${OTA_CLI_MODE}" ] || error_exit "start requires --mode=ab|recovery"
    [ -n "${OTA_CLI_PACKAGE}" ] || error_exit "start requires an OTA package path"
}

dispatch_by_state_mode() {
    local action="$1"
    local current_mode
    current_mode="$(state_get OTA_MODE)"

    case "${current_mode}" in
        ab)
            require_mode_backend "ab"
            case "${action}" in
                status) ab_status ;;
                mark-success) ab_mark_success ;;
                rollback) ab_rollback ;;
            esac
            ;;
        recovery)
            require_mode_backend "recovery"
            case "${action}" in
                status) recovery_status ;;
                mark-success) recovery_mark_success ;;
                rollback) recovery_rollback ;;
            esac
            ;;
        *)
            if [ "${action}" = "status" ]; then
                echo "=== Armbian OTA Status ==="
                echo "Mode: unknown"
                echo "Status: $(state_get STATUS)"
                exit 0
            fi
            error_exit "No OTA mode recorded in ${OTA_STATE_FILE}. Start an OTA first."
            ;;
    esac
}

case "${1:-}" in
    start)
        shift
        parse_start_args "$@"
        case "${OTA_CLI_MODE}" in
            ab)
                require_mode_backend "ab"
                ab_start_ota "${OTA_CLI_PACKAGE}"
                ;;
            recovery)
                require_mode_backend "recovery"
                recovery_start_ota "${OTA_CLI_PACKAGE}"
                ;;
            *)
                error_exit "Unsupported mode: ${OTA_CLI_MODE}"
                ;;
        esac
        ;;
    status)
        state_init
        dispatch_by_state_mode "status"
        ;;
    mark-success)
        state_init
        dispatch_by_state_mode "mark-success"
        ;;
    rollback)
        state_init
        dispatch_by_state_mode "rollback"
        ;;
    *)
        cat <<'EOF'
Usage:
  armbian-ota start --mode=ab <ota-package.tar.gz>
  armbian-ota start --mode=recovery <ota-package.tar.gz>
  armbian-ota status
  armbian-ota mark-success
  armbian-ota rollback
EOF
        exit 1
        ;;
esac
