	echo "CFLAGS += -I/usr/include/libnl3/" >> hostapd/.config
	echo "CFLAGS += -I/usr/include/linux-private/" >> hostapd/.config
	echo "LIBS += -L/usr/lib/aarch64-linux-gnu/" >> hostapd/.config
	echo "LIBS_c += -L/usr/lib/aarch64-linux-gnu/" >> hostapd/.config
	echo "LIBS_p += -L/usr/lib/aarch64-linux-gnu/" >> hostapd/.config
	echo "CFLAGS += -I/usr/include/openssl/" >> hostapd/.config
	echo "LIBS += -L/usr/lib/aarch64-linux-gnu/" >> hostapd/.config
	echo "LIBS_c += -L/usr/lib/aarch64-linux-gnu/" >> hostapd/.config
	echo "LIBS_p += -L/usr/lib/aarch64-linux-gnu/" >> hostapd/.config
	echo "LDFLAGS += -lpthread -lm" >> hostapd/.config
	echo "CONFIG_LIBNL32=y" >> hostapd/.config

